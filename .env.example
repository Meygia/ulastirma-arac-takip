# Yerel geliştirme
DATABASE_URL="file:./dev.db"

# Vercel / Turso (üretim)
# DATABASE_URL="libsql://your-database-name-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Kullanıcı girişi
# AUTH_SECRET: rastgele uzun bir metin (ör. openssl rand -base64 32)
AUTH_SECRET="yerel-gelistirme-icin-degistirin"
# AUTH_USERS: kullanici:sifre,kullanici2:sifre2
AUTH_USERS="admin:sifre123"

# Kilometre senkronu (cibmutfak Araç Takip)
KM_SENKRON_AKTIF="true"
KM_SENKRON_URL="https://arac.cibmutfak.com"
KM_SENKRON_SIFRE="kaynak-site-yonetici-sifresi"

# Araç belgeleri (Vercel Blob — production zorunlu)
# Vercel Dashboard → Storage → Blob → Create → BLOB_READ_WRITE_TOKEN
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
